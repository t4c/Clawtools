# ============================================================
# ddns-aditsystems — Environment configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file!
# ============================================================

# --- AD IT Systems API ---

# SOAP API endpoint (default is correct for aditsystems.de)
DDNS_API_URL=https://dns.aditsystems.de/api/api.php

# Your AD IT Systems control panel username
DDNS_USERNAME=your_username_here

# Your AD IT Systems control panel password
DDNS_PASSWORD=your_secure_password_here

# Fully qualified domain name to update (must be managed in your account)
DDNS_HOSTNAME=your.domain.example.com

# DNS TTL in seconds (default: 300)
DDNS_TTL=300

# --- Local state ---

# File to cache the last known IP (prevents unnecessary API calls)
DDNS_IP_CACHE=/var/cache/ddns-aditsystems/last-ip

# Log file path (leave empty to log to stdout only)
DDNS_LOG_FILE=/var/log/ddns-aditsystems/update.log

# --- IP detection ---

# Public URL that returns just the IPv4 address as plain text
DDNS_IP_CHECK_URL=https://api4.ipify.org

# --- Flask HTTP server (ddns_server.py only) ---

# Interface to bind to (0.0.0.0 = all interfaces)
DDNS_SERVER_HOST=0.0.0.0

# Port to listen on (default: 8053)
DDNS_SERVER_PORT=8053

# Optional Basic Auth for the /update and /force endpoints
# Leave empty to disable authentication (NOT recommended for public servers)
DDNS_SERVER_AUTH_USER=
DDNS_SERVER_AUTH_PASS=

# Set to "true" to enable Flask debug mode (development only!)
DDNS_SERVER_DEBUG=false
